
# Agentic AutoML mock planner endpoints (PR-03)
from backend.agents import SupervisorPlanner
from backend.agents.executor import execute_agent_run
from backend.agents.planner_interface import create_agent_plan
from backend.agents.persistence import (
    create_goal_first_agent_run,
    create_analysis_run,
    create_analysis_steps_from_plan,
    create_decision,
    get_goal_first_agent_run,
    get_analysis_timeline,
    get_analysis_run_trace,
    list_human_review_requests,
    list_goal_first_agent_runs,
    resolve_human_review_request,
    update_analysis_run_status,
)
from backend.agents.mock_runner import run_mock_agent_timeline
from backend.tools import build_pr04_mock_registry


class AgentMockPlanBody(BaseModel):
    user_goal: str
    project_id: str | None = None
    dataset_id: str | None = None
    csv_text: str | None = None
    records: list[dict] | None = None
    file_path: str | None = None


class AgentGoalRunBody(BaseModel):
    goal_text: str
    project_id: str | None = None
    dataset_id: str | None = None
    target_preference: str | None = None
    goal_dataset_warning: bool = False
    mismatch_warning: str | None = None


class AgentReviewResolveBody(BaseModel):
    selected_option: str
    user_note: str | None = None


def _agent_run_aliases(payload: dict) -> dict:
    run = payload.get("agent_run") or payload.get("analysis_run") or payload.get("run") or {}
    return {
        "analysis_run_id": payload.get("analysis_run_id") or run.get("id"),
        "agent_run_id": payload.get("agent_run_id") or payload.get("analysis_run_id") or run.get("id"),
        "id": payload.get("id") or run.get("id"),
        "status": payload.get("status") or run.get("status"),
        "project_id": payload.get("project_id") or run.get("project_id"),
        "dataset_id": payload.get("dataset_id") or run.get("dataset_id"),
        "user_goal": payload.get("user_goal") or run.get("user_goal"),
    }


def _dataset_summary_for_run(conn, run: dict | None) -> dict | None:
    if not run:
        return None
    dataset_id = run.get("dataset_id")
    project_id = run.get("project_id")
    user_id = run.get("user_id")
    if dataset_id:
        try:
            row = conn.execute(
                "SELECT * FROM datasets WHERE id=? AND (? IS NULL OR user_id=?)",
                (dataset_id, user_id, user_id),
            ).fetchone()
            if row:
                item = dict(row)
                quality = _safe_json(item.get("quality"), {}) if "_safe_json" in globals() else {}
                return {
                    "dataset_id": item.get("id"),
                    "id": item.get("id"),
                    "project_id": item.get("project_id"),
                    "filename": item.get("filename"),
                    "original_filename": item.get("original_filename") or item.get("filename"),
                    "row_count": item.get("rows"),
                    "column_count": item.get("columns"),
                    "target_col": item.get("target_col"),
                    "domain": item.get("domain"),
                    "target_quality": (quality or {}).get("target_quality"),
                    "quality_summary": quality,
                }
        except Exception:
            pass
    current = STATE.get("current_dataset") if "STATE" in globals() else None
    current_id = str((current or {}).get("id") or (current or {}).get("dataset_id") or "")
    if dataset_id and current_id == str(dataset_id):
        return {
            "dataset_id": current_id,
            "id": current_id,
            "project_id": (current or {}).get("project_id") or project_id,
            "filename": (current or {}).get("filename"),
            "row_count": (current or {}).get("rows") or (current or {}).get("row_count"),
            "column_count": (current or {}).get("columns") or (current or {}).get("column_count"),
            "target_col": (current or {}).get("target_col"),
            "domain": (current or {}).get("domain"),
        }
    return None


def _attach_dataset_summary(conn, trace: dict) -> dict:
    run = trace.get("analysis_run") or trace.get("run") or trace.get("agent_run") or {}
    dataset = _dataset_summary_for_run(conn, run)
    if dataset:
        trace = {**trace, "dataset": dataset, "dataset_info": dataset}
    return trace


@app.post("/api/agent-runs")
async def create_goal_first_agent_run_api(
    body: AgentGoalRunBody,
    user=Depends(get_current_user),
):
    require_current_user(user)
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    if "enforce_training_job_limits" in globals():
        enforce_training_job_limits(user)
    goal_text = (body.goal_text or "").strip()
    if not goal_text:
        raise HTTPException(400, "분석 목표를 입력해 주세요.")
    planner_result = create_agent_plan(goal_text, body.target_preference)
    interpreted_goal = planner_result["interpreted_goal"]
    plan = planner_result["plan"]
    conn = get_db()
    try:
        result = create_goal_first_agent_run(
            conn,
            goal_text,
            interpreted_goal,
            plan,
            user_id=user.get("sub"),
            project_id=body.project_id,
            dataset_id=body.dataset_id,
        )
        agent_run = result.get("agent_run") or {}
        if body.goal_dataset_warning:
            create_decision(
                conn,
                agent_run.get("id"),
                "goal_dataset_mismatch_warning",
                body.mismatch_warning or "The user chose to proceed even though the analysis goal may not match the selected dataset.",
                decision_type="goal_dataset_mismatch_warning",
                summary="Analysis goal may not match the selected dataset, and the user chose to proceed.",
                selected_value={
                    "goal_text": goal_text,
                    "dataset_id": body.dataset_id,
                    "project_id": body.project_id,
                    "target_preference": body.target_preference,
                },
            )
    finally:
        conn.close()
    if "increment_daily_usage" in globals():
        increment_daily_usage(user.get("sub"), "jobs_today")
    agent_run = result.get("agent_run") or {}
    return {
        **result,
        "analysis_run_id": agent_run.get("id"),
        "status": agent_run.get("status"),
        "project_id": agent_run.get("project_id"),
        "dataset_id": agent_run.get("dataset_id"),
        "user_goal": agent_run.get("user_goal"),
        "interpreted_goal": agent_run.get("interpreted_goal"),
        "plan": result.get("plan"),
        "agent_status": "planned_only",
        "planner": planner_result["planner"],
        "message": "Agent Run과 실행 계획을 저장했습니다. 실제 tool 실행은 PR-28에서 연결됩니다.",
    }


@app.get("/api/agent-runs")
async def list_goal_first_agent_runs_api(user=Depends(get_current_user)):
    require_current_user(user)
    conn = get_db()
    try:
        runs = list_goal_first_agent_runs(conn, user_id=user.get("sub"))
    finally:
        conn.close()
    return {
        "agent_runs": runs,
        "runs": runs,
        "agent_status": "planned_only",
        "message": "저장된 목표 기반 Agent Run 목록입니다.",
    }


@app.get("/api/agent-runs/{analysis_run_id}")
async def get_goal_first_agent_run_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        result = get_goal_first_agent_run(conn, analysis_run_id)
    finally:
        conn.close()
    if not result:
        raise HTTPException(404, "Agent Run을 찾을 수 없습니다.")
    return {
        **result,
        "agent_status": "planned_only",
        "message": "저장된 목표 기반 Agent Run입니다. 아직 실제 tool 실행 기록은 없습니다.",
    }


@app.post("/api/agent-runs/{analysis_run_id}/execute")
async def execute_goal_first_agent_run_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        trace = execute_agent_run(conn, analysis_run_id)
        trace = _attach_dataset_summary(conn, trace or {})
    finally:
        conn.close()
    if not trace:
        raise HTTPException(404, "Agent Run trace를 찾을 수 없습니다.")
    return {
        **trace,
        **_agent_run_aliases(trace),
        "agent_status": "executed_trace",
        "message": "등록된 tool handler 실행 결과를 trace로 저장했습니다.",
    }


@app.get("/api/agent-runs/{analysis_run_id}/trace")
async def get_goal_first_agent_trace_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        trace = get_analysis_timeline(conn, analysis_run_id)
        trace = _attach_dataset_summary(conn, trace or {})
    finally:
        conn.close()
    if not trace:
        raise HTTPException(404, "Agent Run trace를 찾을 수 없습니다.")
    return {
        **trace,
        **_agent_run_aliases(trace),
        "agent_status": "trace",
        "message": "저장된 Agent Run 실행 trace입니다.",
    }


@app.get("/api/agent-runs/{analysis_run_id}/reviews")
async def list_agent_reviews_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        reviews = list_human_review_requests(conn, analysis_run_id)
    finally:
        conn.close()
    return {"reviews": reviews}


@app.post("/api/agent-runs/{analysis_run_id}/reviews/{review_id}/resolve")
async def resolve_agent_review_api(
    analysis_run_id: str,
    review_id: str,
    body: AgentReviewResolveBody,
    user=Depends(get_current_user),
):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        review = resolve_human_review_request(
            conn,
            analysis_run_id,
            review_id,
            selected_option=body.selected_option,
            user_note=body.user_note,
        )
        if not review:
            raise HTTPException(404, "Review request를 찾을 수 없습니다.")
        create_decision(
            conn,
            analysis_run_id,
            f"human_review:{body.selected_option}",
            body.user_note or "사용자가 human review 요청을 처리했습니다.",
            decision_type="human_review_resolution",
            summary=f"Human review resolved as {body.selected_option}.",
            selected_value={"review_id": review_id, "selected_option": body.selected_option},
        )
        if body.selected_option in ("stop", "reject"):
            update_analysis_run_status(conn, analysis_run_id, "stopped")
        elif body.selected_option in ("approve", "continue", "exclude") or body.selected_option.startswith("select:"):
            update_analysis_run_status(conn, analysis_run_id, "planned")
    finally:
        conn.close()
    return {"review": review, "message": "Human review 처리가 저장되었습니다."}


@app.post("/api/agent-runs/{analysis_run_id}/retry-step")
async def retry_agent_step_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        update_analysis_run_status(conn, analysis_run_id, "planned")
        trace = execute_agent_run(conn, analysis_run_id)
    finally:
        conn.close()
    return {**trace, "message": "기존 trace를 보존한 채 재시도를 실행했습니다."}


@app.post("/api/agent-runs/{analysis_run_id}/stop")
async def stop_agent_run_api(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id)
    conn = get_db()
    try:
        update_analysis_run_status(conn, analysis_run_id, "stopped")
        create_decision(
            conn,
            analysis_run_id,
            "stop_run",
            "사용자가 Agent Run을 중단했습니다. 기존 trace는 보존됩니다.",
            decision_type="human_stop",
            summary="Agent Run stopped by user.",
        )
        trace = get_analysis_timeline(conn, analysis_run_id)
    finally:
        conn.close()
    return {**trace, "message": "Agent Run을 중단했습니다."}


@app.get("/api/agent/tools")
async def list_agent_mock_tools():
    registry = build_pr04_mock_registry()
    return {
        "agent_status": "mock_registry_only",
        "tools": registry.describe(),
        "message": "PR-06 registry includes deterministic safety tools. Tools do not call real AutoML logic.",
    }


@app.post("/api/agent/mock-plan")
async def create_agent_mock_plan(
    body: AgentMockPlanBody,
    user=Depends(get_current_user),
):
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    planner = SupervisorPlanner()
    plan = planner.create_initial_plan(body.user_goal)
    conn = get_db()
    try:
        user_id = user.get("sub") if user else None
        run_id = create_analysis_run(
            conn,
            plan.goal,
            user_id=user_id,
            project_id=body.project_id,
            dataset_id=body.dataset_id,
            status="draft",
        )
        steps = create_analysis_steps_from_plan(conn, run_id, plan)
    finally:
        conn.close()
    return {
        "analysis_run_id": run_id,
        "status": "draft",
        "goal": plan.goal,
        "steps": steps,
        "agent_status": "mock_planner_only",
        "message": "PR-03 stores a deterministic mock plan only. No LLM or AutoML tool was called.",
    }


@app.get("/api/agent/runs/{analysis_run_id}")
async def get_agent_mock_run(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id, allow_guest_legacy=True)
    conn = get_db()
    try:
        trace = get_analysis_run_trace(conn, analysis_run_id)
    finally:
        conn.close()
    if not trace:
        raise HTTPException(404, "Agent analysis run not found")
    return {
        **trace,
        "agent_status": "mock_trace_only",
        "message": "This run contains stored PR-03 mock planner trace data.",
    }


@app.post("/api/agent/mock-timeline")
async def create_agent_mock_timeline(
    body: AgentMockPlanBody,
    user=Depends(get_current_user),
):
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    conn = get_db()
    try:
        user_id = user.get("sub") if user else None
        tool_arguments = {}
        if body.csv_text:
            tool_arguments["csv_text"] = body.csv_text
        if body.records:
            tool_arguments["records"] = body.records
        if body.file_path:
            tool_arguments["file_path"] = body.file_path
        result = run_mock_agent_timeline(
            conn,
            body.user_goal,
            user_id=user_id,
            project_id=body.project_id,
            dataset_id=body.dataset_id,
            tool_arguments=tool_arguments,
        )
    finally:
        conn.close()
    return result


@app.get("/api/agent/runs/{analysis_run_id}/timeline")
async def get_agent_mock_timeline(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id, allow_guest_legacy=True)
    conn = get_db()
    try:
        timeline = get_analysis_timeline(conn, analysis_run_id)
    finally:
        conn.close()
    if not timeline:
        raise HTTPException(404, "Agent analysis run timeline not found")
    return {
        **timeline,
        "agent_status": "mock_timeline_only",
        "message": "This timeline contains mock plan, deterministic tool call, observation, and decision records.",
    }
