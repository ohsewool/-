
# Agentic AutoML mock planner endpoints (PR-03)
from backend.agents import SupervisorPlanner
from backend.agents.persistence import (
    create_analysis_run,
    create_analysis_steps_from_plan,
    get_analysis_timeline,
    get_analysis_run_trace,
)
from backend.agents.mock_runner import run_mock_agent_timeline
from backend.tools import build_pr04_mock_registry


class AgentMockPlanBody(BaseModel):
    user_goal: str
    project_id: str | None = None
    dataset_id: str | None = None
    csv_text: str | None = None
    records: list[dict] | None = None
    file_path: str | None = None


class AgentGoalRunBody(BaseModel):
    user_goal: str
    project_id: str | None = None
    dataset_id: str | None = None


def _plan_steps_payload(steps):
    return [{
        "id": step.get("id"),
        "step_index": step.get("step_index"),
        "title": step.get("title"),
        "status": step.get("status"),
        "payload": step.get("payload") or {},
    } for step in steps]


@app.post("/api/agent/runs")
async def create_goal_first_agent_run(
    body: AgentGoalRunBody,
    user=Depends(get_current_user),
):
    goal = (body.user_goal or "").strip()
    if len(goal) < 6:
        raise HTTPException(400, "분석 목표를 조금 더 구체적으로 입력해 주세요.")
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    planner = SupervisorPlanner()
    plan = planner.create_initial_plan(goal)
    supported = planner.is_supported_goal(goal)
    status = "planned" if supported else "needs_review"
    conn = get_db()
    try:
        user_id = user.get("sub") if user else None
        run_id = create_analysis_run(
            conn,
            plan.goal,
            user_id=user_id,
            project_id=body.project_id,
            dataset_id=body.dataset_id,
            status=status,
        )
        steps = create_analysis_steps_from_plan(conn, run_id, plan)
    finally:
        conn.close()
    return {
        "analysis_run_id": run_id,
        "status": status,
        "goal": plan.goal,
        "supported": supported,
        "steps": _plan_steps_payload(steps),
        "agent_status": "planned_only",
        "message": "PR-27은 목표와 deterministic plan만 저장합니다. 아직 tool execution은 수행하지 않습니다.",
    }


@app.get("/api/agent/tools")
async def list_agent_mock_tools():
    registry = build_pr04_mock_registry()
    return {
        "agent_status": "mock_registry_only",
        "tools": registry.describe(),
        "message": "PR-06 registry includes deterministic safety tools. Tools do not call real AutoML logic.",
    }


@app.post("/api/agent/mock-plan")
async def create_agent_mock_plan(
    body: AgentMockPlanBody,
    user=Depends(get_current_user),
):
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    planner = SupervisorPlanner()
    plan = planner.create_initial_plan(body.user_goal)
    conn = get_db()
    try:
        user_id = user.get("sub") if user else None
        run_id = create_analysis_run(
            conn,
            plan.goal,
            user_id=user_id,
            project_id=body.project_id,
            dataset_id=body.dataset_id,
            status="draft",
        )
        steps = create_analysis_steps_from_plan(conn, run_id, plan)
    finally:
        conn.close()
    return {
        "analysis_run_id": run_id,
        "status": "draft",
        "goal": plan.goal,
        "steps": steps,
        "agent_status": "mock_planner_only",
        "message": "PR-03 stores a deterministic mock plan only. No LLM or AutoML tool was called.",
    }


@app.get("/api/agent/runs/{analysis_run_id}")
async def get_agent_mock_run(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id, allow_guest_legacy=True)
    conn = get_db()
    try:
        trace = get_analysis_run_trace(conn, analysis_run_id)
    finally:
        conn.close()
    if not trace:
        raise HTTPException(404, "Agent analysis run not found")
    return {
        **trace,
        "agent_status": "planned_or_trace",
        "message": "Stored Agent Run data. PR-27 runs contain a persisted goal and pending deterministic plan only.",
    }


@app.post("/api/agent/mock-timeline")
async def create_agent_mock_timeline(
    body: AgentMockPlanBody,
    user=Depends(get_current_user),
):
    assert_project_and_dataset_access(user, body.project_id, body.dataset_id)
    conn = get_db()
    try:
        user_id = user.get("sub") if user else None
        tool_arguments = {}
        if body.csv_text:
            tool_arguments["csv_text"] = body.csv_text
        if body.records:
            tool_arguments["records"] = body.records
        if body.file_path:
            tool_arguments["file_path"] = body.file_path
        result = run_mock_agent_timeline(
            conn,
            body.user_goal,
            user_id=user_id,
            project_id=body.project_id,
            dataset_id=body.dataset_id,
            tool_arguments=tool_arguments,
        )
    finally:
        conn.close()
    return result


@app.get("/api/agent/runs/{analysis_run_id}/timeline")
async def get_agent_mock_timeline(analysis_run_id: str, user=Depends(get_current_user)):
    assert_analysis_run_owner(user, analysis_run_id, allow_guest_legacy=True)
    conn = get_db()
    try:
        timeline = get_analysis_timeline(conn, analysis_run_id)
    finally:
        conn.close()
    if not timeline:
        raise HTTPException(404, "Agent analysis run timeline not found")
    return {
        **timeline,
        "agent_status": "mock_timeline_only",
        "message": "This timeline contains mock plan, deterministic tool call, observation, and decision records.",
    }
