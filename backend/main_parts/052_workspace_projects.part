@app.get("/api/datasets/{dataset_id}/delete-impact")
async def get_dataset_delete_impact(dataset_id: str, user=Depends(get_current_user)):
    row = assert_dataset_owner(user, dataset_id)
    conn = get_db()
    try:
        impact = _dataset_impact(conn, row, row["user_id"])
    finally:
        conn.close()
    return {
        "dataset_id": dataset_id,
        "filename": row["filename"],
        **impact,
        "delete_policy": "soft_delete",
        "recommended_next_action": "Deleting this dataset will prevent future reruns that depend on the original CSV. Existing reports may remain as historical summaries.",
    }


@app.delete("/api/datasets/{dataset_id}")
async def delete_dataset(dataset_id: str, user=Depends(get_current_user)):
    row = assert_dataset_owner(user, dataset_id)
    conn = get_db()
    try:
        active_job = conn.execute(
            "SELECT * FROM training_jobs WHERE dataset_id=? AND user_id=? AND status IN ('created','queued','running') LIMIT 1",
            (dataset_id, row["user_id"]),
        ).fetchone()
        if active_job:
            raise HTTPException(409, {
                "error_type": "active_job_exists",
                "user_friendly_message": "A training job is already running for this dataset. Please wait for it to finish before deleting.",
                "recommended_next_action": "Refresh job status, then delete the dataset after the job finishes.",
                "active_job_id": active_job["job_id"],
            })
        impact = _dataset_impact(conn, row, row["user_id"])
        now = datetime.now().isoformat()
        conn.execute(
            "UPDATE datasets SET deleted_at=?, delete_status='deleted', retention_status='deleted_retained', updated_at=? WHERE id=? AND user_id=?",
            (now, now, dataset_id, row["user_id"]),
        )
        conn.execute(
            "UPDATE deployed_models SET disabled_at=?, disabled_reason=? WHERE user_id=? AND dataset_ref LIKE ?",
            (now, "linked_dataset_deleted", row["user_id"], f"%{dataset_id}%"),
        )
        if "disable_prediction_tokens_for_project" in globals():
            disable_prediction_tokens_for_project(conn, row["project_id"], row["user_id"], "linked_dataset_deleted")
        conn.commit()
        return {
            "ok": True,
            "dataset_id": dataset_id,
            "deleted_at": now,
            "delete_status": "deleted",
            "impact": impact,
            "recommended_next_action": "Project history remains available, but reruns that require this dataset are disabled.",
        }
    finally:
        conn.close()


@app.get("/api/projects/{project_id}/delete-impact")
async def get_project_delete_impact(project_id: str, user=Depends(get_current_user)):
    project = assert_project_owner(user, project_id)
    conn = get_db()
    try:
        datasets = conn.execute("SELECT * FROM datasets WHERE project_id=? AND user_id=? AND deleted_at IS NULL", (project_id, project["user_id"])).fetchall()
        active_jobs = conn.execute("SELECT * FROM training_jobs WHERE project_id=? AND user_id=? AND status IN ('created','queued','running')", (project_id, project["user_id"])).fetchall()
        prediction_meta = _project_prediction_metadata(conn, project_id, project["user_id"])
        runs = _project_runs(conn, project_id, project["user_id"])
        reports = _project_reports(conn, project_id, project["user_id"])
    finally:
        conn.close()
    return {
        "project_id": project_id,
        "will_archive_project": True,
        "will_soft_delete_datasets": len(datasets),
        "will_disable_rerun": True,
        "linked_analysis_runs": len(runs),
        "linked_reports": len(reports),
        "linked_models": len(prediction_meta),
        "linked_prediction_apis": len(prediction_meta),
        "active_jobs": [{"job_id": row["job_id"], "status": row["status"]} for row in active_jobs],
        "retention_note": "Project deletion is implemented as MVP archive/soft delete. Historical summaries may remain.",
    }


@app.delete("/api/projects/{project_id}")
async def delete_project(project_id: str, user=Depends(get_current_user)):
    project = assert_project_owner(user, project_id)
    conn = get_db()
    try:
        active_jobs = conn.execute(
            "SELECT * FROM training_jobs WHERE project_id=? AND user_id=? AND status IN ('created','queued','running') LIMIT 1",
            (project_id, project["user_id"]),
        ).fetchone()
        if active_jobs:
            raise HTTPException(409, {
                "error_type": "active_job_exists",
                "user_friendly_message": "A training job is already running for this project. Please wait for it to finish before deleting.",
                "recommended_next_action": "Refresh job status, then archive the project after the job finishes.",
                "active_job_id": active_jobs["job_id"],
            })
        now = datetime.now().isoformat()
        conn.execute("UPDATE projects SET deleted_at=?, archive_status='deleted', updated_at=? WHERE id=? AND user_id=?", (now, now, project_id, project["user_id"]))
        conn.execute("UPDATE datasets SET deleted_at=COALESCE(deleted_at, ?), delete_status='deleted', retention_status='deleted_retained', updated_at=? WHERE project_id=? AND user_id=?", (now, now, project_id, project["user_id"]))
        conn.execute(
            "UPDATE deployed_models SET disabled_at=?, disabled_reason=? WHERE user_id=? AND dataset_ref LIKE ?",
            (now, "linked_project_deleted", project["user_id"], f"%{project_id}%"),
        )
        if "disable_prediction_tokens_for_project" in globals():
            disable_prediction_tokens_for_project(conn, project_id, project["user_id"], "linked_project_deleted")
        conn.commit()
        return {
            "ok": True,
            "project_id": project_id,
            "deleted_at": now,
            "archive_status": "deleted",
            "recommended_next_action": "The project is hidden from My Projects. Historical summaries may remain for review.",
        }
    finally:
        conn.close()
