class ProjectBody(BaseModel):
    name: str = "기본 프로젝트"
    description: str = ""


DATASET_RETENTION_DAYS = int(os.getenv("DATASET_RETENTION_DAYS", "30"))
DELETED_ARTIFACT_RETENTION_DAYS = int(os.getenv("DELETED_ARTIFACT_RETENTION_DAYS", "30"))


def _safe_json(raw, fallback=None):
    if raw is None:
        return fallback
    try:
        return json.loads(raw) if isinstance(raw, str) else raw
    except Exception:
        return fallback


def ensure_dataset_management_columns():
    def add_column_once(conn, table, col, col_type):
        try:
            conn.execute(f"ALTER TABLE {table} ADD COLUMN {col} {col_type}")
        except sqlite3.OperationalError as exc:
            if "duplicate column name" not in str(exc).lower():
                raise

    conn = get_db()
    dataset_cols = [r[1] for r in conn.execute("PRAGMA table_info(datasets)").fetchall()]
    for col, col_type in {
        "original_filename": "TEXT",
        "file_size_bytes": "INTEGER",
        "updated_at": "TEXT",
        "deleted_at": "TEXT",
        "delete_status": "TEXT DEFAULT 'active'",
        "retention_status": "TEXT DEFAULT 'active'",
        "source_type": "TEXT DEFAULT 'upload'",
        "is_demo_dataset": "INTEGER DEFAULT 0",
    }.items():
        if col not in dataset_cols:
            add_column_once(conn, "datasets", col, col_type)
    project_cols = [r[1] for r in conn.execute("PRAGMA table_info(projects)").fetchall()]
    if "deleted_at" not in project_cols:
        add_column_once(conn, "projects", "deleted_at", "TEXT")
    if "archive_status" not in project_cols:
        add_column_once(conn, "projects", "archive_status", "TEXT DEFAULT 'active'")
    deploy_cols = [r[1] for r in conn.execute("PRAGMA table_info(deployed_models)").fetchall()]
    if "disabled_at" not in deploy_cols:
        add_column_once(conn, "deployed_models", "disabled_at", "TEXT")
    if "disabled_reason" not in deploy_cols:
        add_column_once(conn, "deployed_models", "disabled_reason", "TEXT")
    conn.commit()
    conn.close()


def _metric_from_history(item):
    task_type = item.get("task_type")
    first = (item.get("results") or [{}])[0]
    if task_type == "regression":
        return {"name": "R2", "value": first.get("r2")}
    return {"name": "ROC-AUC", "value": first.get("roc_auc", first.get("accuracy"))}


def _history_project_id(item):
    ref = item.get("dataset_ref") or {}
    return ref.get("project_id")


def _run_history_item(row):
    item = _safe_json(row["data"], {}) or {}
    metric = _metric_from_history(item)
    warnings_count = len(item.get("risk_notes") or item.get("warnings") or [])
    report_id = f"experiment-{row['id']}" if item.get("best_model") else None
    return {
        "analysis_run_id": f"experiment-{row['id']}",
        "source": "experiment_history",
        "created_at": row["created_at"],
        "status": item.get("status") or "succeeded",
        "goal": item.get("dataset_domain") or item.get("target_category") or "Saved CSV analysis",
        "target": item.get("target"),
        "task_type": item.get("task_type"),
        "best_model": item.get("best_model"),
        "metric_name": metric["name"],
        "metric_value": metric["value"],
        "warnings_count": warnings_count,
        "report_id": report_id,
        "can_rerun": bool(item.get("reuse_config") or item.get("dataset_ref")),
        "failure_message": item.get("error_message") if item.get("status") == "failed" else None,
        "reuse_config": item.get("reuse_config"),
    }


def _agent_run_item(row):
    return {
        "analysis_run_id": row["id"],
        "source": "agent_trace",
        "created_at": row["created_at"],
        "status": row["status"],
        "goal": row["user_goal"],
        "target": None,
        "task_type": None,
        "best_model": None,
        "metric_name": None,
        "metric_value": None,
        "warnings_count": 0,
        "report_id": None,
        "can_rerun": False,
        "failure_message": None,
        "reuse_config": None,
    }


def _project_prediction_metadata(conn, project_id, user_id):
    rows = conn.execute(
        "SELECT * FROM deployed_models WHERE user_id=? ORDER BY created_at DESC",
        (user_id,),
    ).fetchall()
    out = []
    for row in rows:
        dataset_ref = _safe_json(row["dataset_ref"], {}) or {}
        if dataset_ref.get("project_id") != project_id:
            continue
        out.append({
            "model_id": row["id"],
            "name": row["name"],
            "best_model_name": row["best_model_name"],
            "target_col": row["target_col"],
            "task_type": row["task_type"],
            "created_at": row["created_at"],
            "predict_url": f"/api/v2/{row['id']}/predict",
        })
    return out


def _dataset_deleted(row):
    return bool(row and (row["deleted_at"] if "deleted_at" in row.keys() else None))


def _dataset_impact(conn, dataset, user_id):
    dataset_ref_id = dataset["id"]
    project_id = dataset["project_id"]
    experiments = conn.execute(
        "SELECT id, data FROM experiments WHERE user_id=? ORDER BY id DESC LIMIT 500",
        (user_id,),
    ).fetchall()
    linked_runs = 0
    linked_reports = 0
    for row in experiments:
        item = _safe_json(row["data"], {}) or {}
        ref = item.get("dataset_ref") or {}
        if ref.get("id") == dataset_ref_id or ref.get("dataset_id") == dataset_ref_id:
            linked_runs += 1
            if item.get("best_model"):
                linked_reports += 1
    linked_models = 0
    linked_prediction_apis = 0
    deployed_rows = conn.execute(
        "SELECT * FROM deployed_models WHERE user_id=? ORDER BY created_at DESC",
        (user_id,),
    ).fetchall()
    for row in deployed_rows:
        ref = _safe_json(row["dataset_ref"], {}) or {}
        if ref.get("id") == dataset_ref_id or ref.get("dataset_id") == dataset_ref_id or ref.get("project_id") == project_id:
            linked_models += 1
            linked_prediction_apis += 1
    return {
        "will_delete_dataset_file": False,
        "will_disable_rerun": True,
        "linked_analysis_runs": linked_runs,
        "linked_reports": linked_reports,
        "linked_models": linked_models,
        "linked_prediction_apis": linked_prediction_apis,
        "will_revoke_prediction_api": linked_prediction_apis > 0,
        "retention_note": f"Dataset metadata is soft-deleted. Historical summaries may remain for up to {DELETED_ARTIFACT_RETENTION_DAYS} days in this MVP foundation.",
    }


def _dataset_payload(row, conn=None):
    item = dict(row)
    quality = _safe_json(item.get("quality"), {}) or {}
    deleted = bool(item.get("deleted_at"))
    item.update({
        "dataset_id": item.get("id"),
        "original_filename": item.get("original_filename") or item.get("filename"),
        "row_count": item.get("rows"),
        "column_count": item.get("columns"),
        "delete_status": item.get("delete_status") or ("deleted" if deleted else "active"),
        "retention_status": item.get("retention_status") or ("deleted_retained" if deleted else "active"),
        "source_type": item.get("source_type") or "upload",
        "is_demo_dataset": bool(item.get("is_demo_dataset") or 0),
        "quality_summary": quality,
        "linked_analysis_run_count": None,
        "linked_report_count": None,
        "linked_model_count": None,
        "has_prediction_api": None,
    })
    if conn is not None:
        impact = _dataset_impact(conn, row, item["user_id"])
        item.update({
            "linked_analysis_run_count": impact["linked_analysis_runs"],
            "linked_report_count": impact["linked_reports"],
            "linked_model_count": impact["linked_models"],
            "has_prediction_api": impact["linked_prediction_apis"] > 0,
        })
    return item


def _project_last_job(conn, project_id, user_id):
    try:
        row = conn.execute(
            "SELECT * FROM training_jobs WHERE project_id=? AND user_id=? ORDER BY created_at DESC LIMIT 1",
            (project_id, user_id),
        ).fetchone()
    except sqlite3.OperationalError:
        return None
    if not row:
        return None
    return {
        "job_id": row["job_id"],
        "status": row["status"],
        "progress_message": row["progress_message"],
        "finished_at": row["finished_at"],
        "failed_at": row["failed_at"],
        "error_type": row["error_type"],
        "error_message": row["error_message"],
        "recommended_next_action": row["recommended_next_action"],
        "rerun_of": row["rerun_of"] if "rerun_of" in row.keys() else None,
    }


def _project_job_rollup(conn, project_id, user_id, last_job=None):
    try:
        rows = conn.execute(
            "SELECT * FROM training_jobs WHERE project_id=? AND user_id=? ORDER BY created_at DESC LIMIT 200",
            (project_id, user_id),
        ).fetchall()
    except sqlite3.OperationalError:
        return {
            "last_failed_at": None,
            "last_error_type": None,
            "last_error_message": None,
            "last_recommended_next_action": None,
            "can_rerun": False,
            "rerun_count": 0,
            "rerun_of": None,
            "latest_rerun_id": None,
            "active_job_id": None,
            "active_job_status": None,
        }
    failed = next((row for row in rows if row["status"] == "failed"), None)
    active = next((row for row in rows if row["status"] in ("created", "queued", "running")), None)
    latest_rerun = next((row for row in rows if "rerun_of" in row.keys() and row["rerun_of"]), None)
    return {
        "last_failed_at": failed["failed_at"] if failed else None,
        "last_error_type": failed["error_type"] if failed else None,
        "last_error_message": failed["error_message"] if failed else None,
        "last_recommended_next_action": failed["recommended_next_action"] if failed else None,
        "can_rerun": bool(last_job and last_job.get("status") in ("failed", "succeeded", "cancelled", "needs_review")),
        "rerun_count": sum(1 for row in rows if "rerun_of" in row.keys() and row["rerun_of"]),
        "rerun_of": latest_rerun["rerun_of"] if latest_rerun else None,
        "latest_rerun_id": latest_rerun["job_id"] if latest_rerun else None,
        "active_job_id": active["job_id"] if active else None,
        "active_job_status": active["status"] if active else None,
    }


def _project_runs(conn, project_id, user_id):
    runs = []
    rows = conn.execute(
        "SELECT id, data, created_at FROM experiments WHERE user_id=? ORDER BY id DESC LIMIT 200",
        (user_id,),
    ).fetchall()
    for row in rows:
        item = _safe_json(row["data"], {}) or {}
        if _history_project_id(item) == project_id:
            runs.append(_run_history_item(row))
    try:
        agent_rows = conn.execute(
            "SELECT * FROM analysis_runs WHERE user_id=? AND project_id=? ORDER BY created_at DESC LIMIT 100",
            (user_id, project_id),
        ).fetchall()
        runs.extend(_agent_run_item(row) for row in agent_rows)
    except sqlite3.OperationalError:
        pass
    return sorted(runs, key=lambda row: row.get("created_at") or "", reverse=True)


def _project_reports(conn, project_id, user_id):
    reports = []
    for run in _project_runs(conn, project_id, user_id):
        if not run.get("report_id"):
            continue
        reports.append({
            "report_id": run["report_id"],
            "analysis_run_id": run["analysis_run_id"],
            "created_at": run["created_at"],
            "title": f"{run.get('target') or 'CSV'} analysis report",
            "status": "metadata_available",
            "export_available": False,
            "message": "Saved report metadata is available. HTML export uses the current analysis session until report persistence is added.",
        })
    return reports


def _project_summary(project, datasets, runs, prediction_meta, last_job=None, job_rollup=None):
    last_run = runs[0] if runs else None
    latest_dataset = datasets[0] if datasets else None
    job_rollup = job_rollup or {}
    return {
        "project_id": project["id"],
        "id": project["id"],
        "name": project["name"],
        "description": project["description"] or "",
        "created_at": project["created_at"],
        "updated_at": project["updated_at"],
        "deleted_at": project["deleted_at"] if "deleted_at" in project.keys() else None,
        "archive_status": project["archive_status"] if "archive_status" in project.keys() else "active",
        "user_id": project["user_id"],
        "owner_user_id": project["user_id"],
        "last_run_id": last_run.get("analysis_run_id") if last_run else None,
        "last_status": last_run.get("status") if last_run else None,
        "last_target": last_run.get("target") if last_run else None,
        "last_task_type": last_run.get("task_type") if last_run else None,
        "last_best_model": last_run.get("best_model") if last_run else None,
        "last_metric_name": last_run.get("metric_name") if last_run else None,
        "last_metric_value": last_run.get("metric_value") if last_run else None,
        "dataset_name": latest_dataset["filename"] if latest_dataset else None,
        "dataset_summary": dict(latest_dataset) if latest_dataset else None,
        "run_count": len(runs),
        "has_report": any(row.get("report_id") for row in runs),
        "has_prediction_api": bool(prediction_meta),
        "last_job_id": last_job.get("job_id") if last_job else None,
        "last_job_status": last_job.get("status") if last_job else None,
        "last_job_progress_message": last_job.get("progress_message") if last_job else None,
        "last_job_finished_at": last_job.get("finished_at") if last_job else None,
        "last_job_error_message": last_job.get("error_message") if last_job else None,
        **job_rollup,
    }


def ensure_default_project(user_id, name="기본 프로젝트"):
    import uuid
    conn = get_db()
    row = conn.execute(
        "SELECT * FROM projects WHERE user_id=? AND COALESCE(archive_status,'active')='active' AND deleted_at IS NULL ORDER BY created_at ASC LIMIT 1",
        (user_id,),
    ).fetchone()
    if row:
        conn.close()
        return dict(row)
    project_id = str(uuid.uuid4())[:8]
    now = datetime.now().isoformat()
    conn.execute(
        "INSERT INTO projects (id,user_id,name,description,created_at,updated_at) VALUES (?,?,?,?,?,?)",
        (project_id, user_id, name, "자동 생성된 기본 작업공간 프로젝트", now, now),
    )
    conn.commit()
    row = conn.execute("SELECT * FROM projects WHERE id=?", (project_id,)).fetchone()
    conn.close()
    return dict(row)


def save_dataset_record(user, filename, df, target_col, quality, domain_info):
    dataset_meta = {
        "id": None,
        "project_id": None,
        "project_name": None,
        "filename": filename,
        "target_col": str(target_col),
        "rows": int(df.shape[0]),
        "columns": int(df.shape[1]),
        "domain": domain_info.get("dataset_domain"),
    }
    if not user:
        STATE["current_dataset"] = dataset_meta
        return None
    import uuid
    project = ensure_default_project(user["sub"])
    dataset_id = str(uuid.uuid4())[:8]
    now = datetime.now().isoformat()
    conn = get_db()
    conn.execute(
        """INSERT INTO datasets
           (id,project_id,user_id,filename,original_filename,rows,columns,target_col,domain,quality,created_at,updated_at,delete_status,retention_status,source_type,is_demo_dataset)
           VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
        (
            dataset_id, project["id"], user["sub"], filename, filename, int(df.shape[0]), int(df.shape[1]),
            str(target_col), domain_info.get("dataset_domain"), json.dumps(quality, ensure_ascii=False), now, now,
            "active", "active", "upload", 0,
        ),
    )
    conn.execute("UPDATE projects SET updated_at=? WHERE id=?", (now, project["id"]))
    conn.commit()
    conn.close()
    dataset_meta.update({
        "id": dataset_id,
        "project_id": project["id"],
        "project_name": project["name"],
    })
    STATE["current_dataset"] = dataset_meta
    return dataset_meta


ensure_dataset_management_columns()


@app.get("/api/projects")
async def list_projects(user=Depends(get_current_user)):
    if not user:
        return []
    ensure_default_project(user["sub"])
    conn = get_db()
    projects = conn.execute(
        "SELECT * FROM projects WHERE user_id=? AND COALESCE(archive_status,'active')='active' AND deleted_at IS NULL ORDER BY updated_at DESC",
        (user["sub"],),
    ).fetchall()
    out = []
    for row in projects:
        project = dict(row)
        datasets = conn.execute(
            "SELECT * FROM datasets WHERE project_id=? AND user_id=? AND deleted_at IS NULL ORDER BY created_at DESC",
            (project["id"], user["sub"]),
        ).fetchall()
        runs = _project_runs(conn, project["id"], user["sub"])
        prediction_meta = _project_prediction_metadata(conn, project["id"], user["sub"])
        last_job = _project_last_job(conn, project["id"], user["sub"])
        job_rollup = _project_job_rollup(conn, project["id"], user["sub"], last_job)
        summary = _project_summary(project, datasets, runs, prediction_meta, last_job, job_rollup)
        summary["dataset_count"] = len(datasets)
        out.append(summary)
    conn.close()
    return out


@app.get("/api/projects/{project_id}")
async def get_project_detail(project_id: str, user=Depends(get_current_user)):
    project = assert_project_owner(user, project_id)
    conn = get_db()
    try:
        datasets = conn.execute(
            "SELECT * FROM datasets WHERE project_id=? AND user_id=? ORDER BY created_at DESC",
            (project_id, project["user_id"]),
        ).fetchall()
        runs = _project_runs(conn, project_id, project["user_id"])
        reports = _project_reports(conn, project_id, project["user_id"])
        prediction_meta = _project_prediction_metadata(conn, project_id, project["user_id"])
        last_job = _project_last_job(conn, project_id, project["user_id"])
        job_rollup = _project_job_rollup(conn, project_id, project["user_id"], last_job)
    finally:
        conn.close()
    known_warnings = []
    if not datasets:
        known_warnings.append("No dataset metadata is linked to this project yet.")
    if not runs:
        known_warnings.append("No analysis run history is linked to this project yet.")
    summary = _project_summary(project, datasets, runs, prediction_meta, last_job, job_rollup)
    return {
        **summary,
        "datasets": [_dataset_payload(r, conn=None) for r in datasets],
        "analysis_runs": runs,
        "available_reports": reports,
        "prediction_api_metadata": prediction_meta,
        "known_warnings": known_warnings,
        "next_recommended_action": "Open a saved run, review report metadata, or rerun the workflow from the upload screen.",
        "ownership": "owned",
    }


